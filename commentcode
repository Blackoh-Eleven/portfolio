.ticgrid{
    /* background:red; */
    width: 90%;
    aspect-ratio:1/1;
    display: flex;
    justify-content: center;
    align-items:center;
    text-align: center;
    font-size: 20px;
    font-weight: bolder;
    color:darkblue;
}






















nav{
    /* background:red; */
    width: 100%;
    height: 30px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 5px;
    padding-bottom: 10px;
    border-bottom:1px solid rgba(20, 11, 11, 0.1);


}

nav a {
    display: flex;
    color:#FFFFFF;
    text-decoration: none;
    font-weight:bold;
    /* justify-content: center; */
    /* position: absolute; */
}

nav a img {
    width: 8%;
    height: 4%;
    border-radius:50%;
    position: absolute;
    top: 1%;
}

nav a h3{
    color:#000;
    position: relative;
    left: 44%;
    /* bottom:4px; */
    font-family: sans-serif;
    font-size: 17px;

}

nav > .useApp{
    /* background:rgba(72, 235, 50, 0.7); */
    background:#4BCC00;
    height: 30px;
    border-radius:0;
    font-size: 13px;
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    font-weight: 700;
    color:#ffffff;
    border-radius:10px;
    width: 20%;
    box-shadow:0px 4px rgb(17, 145, 17);
    border:none;
}




































