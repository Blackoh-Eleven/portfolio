.nav-area{
    /* height:40px; */
    display:flex;
    flex: 1;
    justify-content: flex-start;
    width: 100%;
    gap: 0;
    border-bottom:1px solid rgba(196,193,193,0.3);
    height: 30px;
    padding: 5px;
}
.arrow{
    display: block;
    flex:0 0 auto;
    font-size: 10px;
    padding:0 10px;
    transform: translateY(30px);
    cursor:pointer;
}

.nav-wrapper{
    overflow:hidden;
    flex: 1;
    width: 100%;
    /* border:1px solid blue; */
    padding: 5px;
    transform: translateY(30px);
}

.nav-list{
    display:flex;
    list-style:none;
    gap:1em;
    font-size:11px;
    white-space:nowrap;
    transition:transform 0.3s ease;
}




.under{
    display: block;
    border-bottom:1px solid rgba(196,193,193,0.3);
    height:20px;
    width: 100%;
    position: absolute;
    top:14%;
}


.nav-area a img{
    position: absolute;
    left: -3%;
    top: 7%;
}











.useapp{
    /* background:rgba(72, 235, 50, 0.7); */
    display: block;
    background:#4BCC00;
    height: 25px;
    font-size: 10px;
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    font-weight: 500;
    color:#ffffff;
    border-radius:5px;
    width: 15%;
    box-shadow:0px 4px rgb(17, 145, 17);
    border:none;
    /* transform: translate(350px,); */
    position: absolute;
    left: 80%;
    top:6.8%;
    height: 22px;
    /* display: flex; */
}





.nav2,.button-nav{
    position: relative;  
    top: 200px;
}




